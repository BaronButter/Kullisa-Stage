Subject: [PATCH] Set Light Modern as default theme

Author: VSCODIUM-EXPERT
Date: 2026-03-12
Time: 20:40 CET
Description: Set Light Modern as default color theme for Kullisa Labs

---
 src/vs/workbench/services/themes/common/workbenchThemeService.ts | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/src/vs/workbench/services/themes/common/workbenchThemeService.ts b/src/vs/workbench/services/themes/common/workbenchThemeService.ts
index 1234567..abcdefg 100644
--- a/src/vs/workbench/services/themes/common/workbenchThemeService.ts
+++ b/src/vs/workbench/services/themes/common/workbenchThemeService.ts
@@ -17,7 +17,7 @@ export const VS_LIGHT_THEME = 'vs';
 export const VS_HC_THEME = 'hc-black';
 export const VS_HC_LIGHT_THEME = 'hc-light';
 
-export const DEFAULT_THEME_ID = 'Default Dark Modern';
+export const DEFAULT_THEME_ID = 'Default Light Modern';
 
 export const ThemeSettings = {
 	COLOR_THEME: 'workbench.colorTheme',
